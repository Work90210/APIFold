{
  "name": "@apifold/registry",
  "version": "0.0.1",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./specs/*": "./specs/*"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --ext .ts src/",
    "test": "vitest run",
    "validate": "tsx src/validate.ts"
  },
  "dependencies": {
    "@apifold/transformer": "workspace:*"
  },
  "devDependencies": {
    "@apifold/eslint-config": "workspace:*",
    "@apifold/tsconfig": "workspace:*",
    "@types/node": "^25.5.0",
    "eslint": "^10.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
